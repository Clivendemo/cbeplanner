# CBE Lesson Planner - Backend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE CONFIGURATION (Required)
# ===========================================
# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com/ -> Connect -> Drivers -> Python
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name (default: cbeplanner)
DB_NAME=cbeplanner

# ===========================================
# SECURITY (Required for Production)
# ===========================================
# JWT Secret for token signing (generate a strong random string)
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===========================================
# FIREBASE CONFIGURATION (Required)
# ===========================================
# Firebase project ID (from Firebase Console -> Project Settings)
FIREBASE_PROJECT_ID=cbeplanner

# Firebase Web API Key (from Firebase Console -> Project Settings -> General)
FIREBASE_API_KEY=your-firebase-api-key

# ===========================================
# M-PESA DARAJA API CONFIGURATION (Required for Payments)
# ===========================================
# Get credentials from: https://developer.safaricom.co.ke/
# Sandbox credentials for testing
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret

# Business Shortcode (Paybill or Till number)
# Sandbox default: 174379
MPESA_SHORTCODE=174379

# Passkey (provided by Safaricom)
# Sandbox default passkey:
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Callback URL (must be publicly accessible HTTPS URL)
# Example: https://your-app.onrender.com/api/payments/mpesa/callback
MPESA_CALLBACK_URL=https://your-backend-url/api/payments/mpesa/callback

# Environment: sandbox or production
MPESA_ENV=sandbox

# ===========================================
# CORS CONFIGURATION (Required for Production)
# ===========================================
# Comma-separated list of allowed origins
# Example: https://your-app.vercel.app,https://www.your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:8081

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Port (Render sets this automatically - DO NOT hardcode)
PORT=10000

# ===========================================
# OPTIONAL SETTINGS
# ===========================================
# Environment (development/staging/production)
ENVIRONMENT=production

# Log level (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
