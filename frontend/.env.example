# CBE Lesson Planner - Frontend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# API CONFIGURATION (Required)
# ===========================================
# Backend API URL (without trailing slash)
# For local development: http://localhost:8001
# For production: https://your-backend.up.railway.app
EXPO_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app

# Alternative naming (same value)
EXPO_PUBLIC_BACKEND_URL=https://your-backend.up.railway.app

# ===========================================
# EXPO CONFIGURATION (Auto-set by Expo)
# ===========================================
# These are typically set automatically
# EXPO_USE_FAST_RESOLVER=1
