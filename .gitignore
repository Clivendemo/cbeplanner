# CBE Lesson Planner - Git Ignore

# ===========================================
# Environment Files (NEVER COMMIT THESE)
# ===========================================
.env
.env.*
.env.local
.env.*.local
*.env
backend/.env
frontend/.env

# ===========================================
# Dependencies
# ===========================================
node_modules/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# ===========================================
# Build Outputs
# ===========================================
dist/
build/
.expo/
web-build/

# ===========================================
# IDE & Editors
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# ===========================================
# OS Files
# ===========================================
.DS_Store
Thumbs.db
*.bak

# ===========================================
# Logs
# ===========================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================================
# Testing & Coverage
# ===========================================
coverage/
.coverage
htmlcov/
.pytest_cache/
test_result.md
test_reports/

# ===========================================
# Secrets & Credentials
# ===========================================
*.pem
*.key
google-services.json
GoogleService-Info.plist
service-account*.json

# ===========================================
# Temporary Files
# ===========================================
tmp/
temp/
*.tmp
*.temp
.metro-cache/

# ===========================================
# Database Exports (may contain sensitive data)
# ===========================================
db_export/
*.dump
*.bson

# ===========================================
# Emergent Platform
# ===========================================
.emergent/
-e 
